{
  "name": "conflictcast",
  "version": "0.1.0",
  "description": "Open-source GitHub App that predicts merge conflicts between open pull requests.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src --ext .ts",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "demo:capture": "ts-node src/demo/captureOpenedFlow.ts --output docs/demo/captures/pull-request-opened.txt",
    "demo:render": "ts-node src/demo/renderOpenedFlow.ts",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "github-app",
    "probot",
    "merge-conflicts",
    "pull-requests",
    "code-review",
    "typescript",
    "sqlite",
    "devops"
  ],
  "author": "Meru143",
  "license": "MIT",
  "homepage": "https://github.com/Meru143/conflictcast#readme",
  "bugs": {
    "url": "https://github.com/Meru143/conflictcast/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Meru143/conflictcast.git"
  },
  "engines": {
    "node": "22.x"
  },
  "type": "commonjs",
  "devDependencies": {
    "@semantic-release/changelog": "6.0.3",
    "@types/better-sqlite3": "7.6.13",
    "@types/js-yaml": "4.0.9",
    "@types/node": "22.13.10",
    "@vitest/coverage-v8": "2.1.9",
    "eslint": "10.0.3",
    "nock": "14.0.11",
    "nodemon": "3.1.14",
    "semantic-release": "24.2.9",
    "ts-node": "10.9.2",
    "typescript": "5.7.3",
    "typescript-eslint": "8.57.1",
    "vitest": "2.1.9"
  },
  "dependencies": {
    "@octokit/rest": "22.0.1",
    "better-sqlite3": "9.6.0",
    "dotenv": "16.6.1",
    "js-yaml": "4.1.1",
    "minimatch": "10.2.4",
    "parse-diff": "0.11.1",
    "pino": "9.14.0",
    "probot": "13.4.7"
  }
}
